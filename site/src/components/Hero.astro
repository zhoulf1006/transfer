---
import { useTranslations, localizedPath, type Locale } from '../i18n/ui'
interface Props { locale: Locale }
const { locale } = Astro.props
const t = useTranslations(locale)
const home = localizedPath(locale, '/')
const GITHUB = 'https://github.com/zhoulf1006/transfer'
---

<section class="hero">
  <div class="container hero-inner">
    <p class="tagline">{t('hero.tagline')}</p>
    <h1 class="hero-title">{t('hero.title')}</h1>
    <p class="hero-sub">{t('hero.subtitle')}</p>
    <div class="hero-cta">
      <a href={`${home}#download`} class="btn btn-primary">{t('hero.cta.download')}</a>
      <a href={GITHUB} target="_blank" rel="noopener" class="btn btn-ghost">{t('hero.cta.github')}</a>
    </div>
    <p class="hero-platforms">{t('hero.platforms')}</p>

    <!-- 应用主界面截图(自带 macOS 窗口栏,不再套假 chrome) -->
    <div class="hero-shot">
      <img
        src="/screenshots/main.png"
        alt={t('hero.shotAlt')}
        width="1800"
        height="1280"
        loading="eager"
      />
    </div>
  </div>

  <style>
    .hero {
      padding-top: 48px;
      padding-bottom: 32px;
      background:
        radial-gradient(1200px 500px at 50% -10%, var(--brand-tint), transparent 70%);
      text-align: center;
    }
    .tagline {
      display: inline-block;
      color: var(--brand);
      font-weight: 600;
      background: var(--brand-tint);
      border: 1px solid var(--border);
      padding: 5px 14px;
      border-radius: 999px;
      font-size: 0.9rem;
      margin: 0 0 20px;
    }
    .hero-title {
      font-size: clamp(1.9rem, 5vw, 3.2rem);
      max-width: 820px;
      margin: 0 auto 18px;
    }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--fg-muted);
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .hero-cta {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .hero-platforms {
      margin-top: 14px;
      color: var(--fg-muted);
      font-size: 0.9rem;
    }
    .hero-shot {
      margin: 32px auto 0;
      max-width: 900px;
    }
    .hero-shot img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }
  </style>
</section>
