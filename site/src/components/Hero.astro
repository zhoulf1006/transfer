---
import { useTranslations, localizedPath, type Locale } from '../i18n/ui'
interface Props { locale: Locale }
const { locale } = Astro.props
const t = useTranslations(locale)
const home = localizedPath(locale, '/')
const GITHUB = 'https://github.com/zhoulf1006/transfer'
---

<section class="hero">
  <div class="container hero-inner">
    <p class="tagline">{t('hero.tagline')}</p>
    <h1 class="hero-title">{t('hero.title')}</h1>
    <p class="hero-sub">{t('hero.subtitle')}</p>
    <div class="hero-cta">
      <a href={`${home}#download`} class="btn btn-primary">{t('hero.cta.download')}</a>
      <a href={GITHUB} target="_blank" rel="noopener" class="btn btn-ghost">{t('hero.cta.github')}</a>
    </div>
    <p class="hero-platforms">{t('hero.platforms')}</p>

    <!-- 主视觉占位:替换为真实应用截图(建议 1280×800 左右,放 site/public/screenshots/main.png) -->
    <div class="hero-shot card" aria-label="app screenshot placeholder">
      <div class="shot-chrome">
        <span></span><span></span><span></span>
      </div>
      <div class="shot-body">
        <span class="shot-note">📷 应用主界面截图占位<br />screenshot placeholder</span>
      </div>
    </div>
  </div>

  <style>
    .hero {
      padding-top: 48px;
      padding-bottom: 32px;
      background:
        radial-gradient(1200px 500px at 50% -10%, var(--brand-tint), transparent 70%);
      text-align: center;
    }
    .tagline {
      display: inline-block;
      color: var(--brand);
      font-weight: 600;
      background: var(--brand-tint);
      border: 1px solid var(--border);
      padding: 5px 14px;
      border-radius: 999px;
      font-size: 0.9rem;
      margin: 0 0 20px;
    }
    .hero-title {
      font-size: clamp(1.9rem, 5vw, 3.2rem);
      max-width: 820px;
      margin: 0 auto 18px;
    }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--fg-muted);
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .hero-cta {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .hero-platforms {
      margin-top: 14px;
      color: var(--fg-muted);
      font-size: 0.9rem;
    }
    .hero-shot {
      margin: 32px auto 0;
      max-width: 900px;
      overflow: hidden;
      text-align: left;
    }
    .shot-chrome {
      display: flex;
      gap: 7px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      background: var(--bg-soft);
    }
    .shot-chrome span {
      width: 11px;
      height: 11px;
      border-radius: 50%;
      background: var(--border);
    }
    .shot-body {
      aspect-ratio: 16 / 9;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        linear-gradient(135deg, var(--brand-tint), var(--bg-soft));
    }
    .shot-note {
      color: var(--fg-muted);
      text-align: center;
      font-size: 0.95rem;
    }
  </style>
</section>
