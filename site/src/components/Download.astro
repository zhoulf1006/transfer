---
import { useTranslations, type Locale } from '../i18n/ui'
import { DOWNLOADS, DOWNLOAD_STATS_URL, VERSION } from '../download-config'
interface Props { locale: Locale }
const { locale } = Astro.props
const t = useTranslations(locale)

const macItems = DOWNLOADS.filter((d) => d.os === 'mac')
const winItems = DOWNLOADS.filter((d) => d.os === 'win')
---

<section id="download" class="download">
  <div class="container">
    <h2 class="section-title">{t('download.title')}</h2>
    <p class="section-sub">
      {t('download.version')}: <strong>v{VERSION}</strong>
    </p>
    <p
      class="download-statistics"
      data-download-statistics
      data-url={DOWNLOAD_STATS_URL}
      aria-live="polite"
      hidden
    >
      {t('download.stats.prefix')} <strong data-download-total></strong> {t('download.stats.suffix')}
      <span aria-hidden="true"> · </span>macOS <strong data-download-macos></strong>
      <span aria-hidden="true"> · </span>Windows <strong data-download-windows></strong>
    </p>

    <div class="dl-grid grid">
      <!-- macOS -->
      <div class="card dl-col">
        <div class="dl-head">
          <span class="dl-os">{t('download.mac.heading')}</span>
        </div>
        {macItems.map((item) => (
          <div class="dl-row">
            <div class="dl-label">{t(item.labelKey)}</div>
            <div class="dl-actions">
              <a class="btn btn-primary btn-sm" href={item.sources.github} target="_blank" rel="noopener">{t('download.source.primary')}</a>
              <a class="dl-alt" href={item.sources.r2}>{t('download.source.cloudflare')}</a>
            </div>
          </div>
        ))}
      </div>

      <!-- Windows -->
      <div class="card dl-col">
        <div class="dl-head">
          <span class="dl-os">{t('download.win.heading')}</span>
        </div>
        {winItems.map((item) => (
          <div class="dl-row">
            <div class="dl-label">{t(item.labelKey)}</div>
            <div class="dl-actions">
              <a class="btn btn-primary btn-sm" href={item.sources.github} target="_blank" rel="noopener">{t('download.source.primary')}</a>
              <a class="dl-alt" href={item.sources.r2}>{t('download.source.cloudflare')}</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    .download {
      background: var(--bg-soft);
    }
    .download-statistics {
      margin: -14px 0 24px;
      text-align: center;
      color: var(--fg-muted);
      font-size: 0.95rem;
    }
    /* 下载按钮更紧凑:覆盖 global .btn 的 12px 22px */
    .dl-actions .btn-sm {
      padding: 7px 16px;
      font-size: 0.9rem;
    }
    .dl-grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
    .dl-col {
      padding: 4px 22px 14px;
    }
    .dl-head {
      padding: 14px 0 8px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
    }
    .dl-os {
      font-weight: 700;
      font-size: 1.1rem;
    }
    .dl-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .dl-row:last-child {
      border-bottom: none;
    }
    .dl-label {
      font-weight: 500;
      font-size: 0.95rem;
    }
    .dl-actions {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .dl-alt {
      font-size: 0.85rem;
      color: var(--fg-muted);
    }
    @media (max-width: 860px) {
      .dl-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>

<script>
  import { parseDownloadSummary } from '../download-statistics'

  for (const element of document.querySelectorAll<HTMLElement>('[data-download-statistics]')) {
    const url = element.dataset.url
    if (!url) continue
    const controller = new AbortController()
    const timeout = window.setTimeout(() => controller.abort(), 5000)
    fetch(url, { signal: controller.signal })
      .then((response) => {
        if (!response.ok) throw new Error(`HTTP ${response.status}`)
        return response.json()
      })
      .then((value) => {
        const summary = parseDownloadSummary(value)
        if (!summary) return
        const total = element.querySelector<HTMLElement>('[data-download-total]')
        const macos = element.querySelector<HTMLElement>('[data-download-macos]')
        const windows = element.querySelector<HTMLElement>('[data-download-windows]')
        if (!total || !macos || !windows) return
        total.textContent = summary.total.toLocaleString()
        macos.textContent = summary.macos.toLocaleString()
        windows.textContent = summary.windows.toLocaleString()
        element.hidden = false
      })
      .catch(() => {})
      .finally(() => window.clearTimeout(timeout))
  }
</script>
