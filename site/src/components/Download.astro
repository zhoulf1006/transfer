---
import { useTranslations, type Locale } from '../i18n/ui'
import { DOWNLOADS, VERSION } from '../download-config'
interface Props { locale: Locale }
const { locale } = Astro.props
const t = useTranslations(locale)

const macItems = DOWNLOADS.filter((d) => d.os === 'mac')
const winItems = DOWNLOADS.filter((d) => d.os === 'win')
---

<section id="download" class="download">
  <div class="container">
    <h2 class="section-title">{t('download.title')}</h2>
    <p class="section-sub">
      {t('download.version')}: <strong>v{VERSION}</strong>
    </p>

    <div class="dl-grid grid">
      <!-- macOS -->
      <div class="card dl-col">
        <div class="dl-head">
          <span class="dl-os">{t('download.mac.heading')}</span>
        </div>
        {macItems.map((item) => (
          <div class="dl-row">
            <div class="dl-label">{t(item.labelKey)}</div>
            <div class="dl-actions">
              <a class="btn btn-primary btn-sm" href={item.sources.github} target="_blank" rel="noopener">{t('download.source.primary')}</a>
              <a class="dl-alt" href={item.sources.r2}>{t('download.source.cloudflare')}</a>
            </div>
          </div>
        ))}
      </div>

      <!-- Windows -->
      <div class="card dl-col">
        <div class="dl-head">
          <span class="dl-os">{t('download.win.heading')}</span>
        </div>
        {winItems.map((item) => (
          <div class="dl-row">
            <div class="dl-label">{t(item.labelKey)}</div>
            <div class="dl-actions">
              <a class="btn btn-primary btn-sm" href={item.sources.github} target="_blank" rel="noopener">{t('download.source.primary')}</a>
              <a class="dl-alt" href={item.sources.r2}>{t('download.source.cloudflare')}</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    .download {
      background: var(--bg-soft);
    }
    /* 下载按钮更紧凑:覆盖 global .btn 的 12px 22px */
    .dl-actions .btn-sm {
      padding: 7px 16px;
      font-size: 0.9rem;
    }
    .dl-grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
    .dl-col {
      padding: 4px 22px 14px;
    }
    .dl-head {
      padding: 14px 0 8px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
    }
    .dl-os {
      font-weight: 700;
      font-size: 1.1rem;
    }
    .dl-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .dl-row:last-child {
      border-bottom: none;
    }
    .dl-label {
      font-weight: 500;
      font-size: 0.95rem;
    }
    .dl-actions {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .dl-alt {
      font-size: 0.85rem;
      color: var(--fg-muted);
    }
    @media (max-width: 860px) {
      .dl-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>
