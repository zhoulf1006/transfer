---
import { useTranslations, type Locale } from '../i18n/ui'
import { DOWNLOADS, VERSION } from '../download-config'
interface Props { locale: Locale }
const { locale } = Astro.props
const t = useTranslations(locale)

const macItems = DOWNLOADS.filter((d) => d.os === 'mac')
const winItems = DOWNLOADS.filter((d) => d.os === 'win')
---

<section id="download" class="download">
  <div class="container">
    <h2 class="section-title">{t('download.title')}</h2>
    <p class="section-sub">
      {t('download.version')}: <strong>v{VERSION}</strong>
    </p>

    <p class="china-hint" data-china-hint hidden>{t('download.china.hint')}</p>

    <div class="dl-grid grid">
      <!-- macOS -->
      <div class="card dl-col">
        <div class="dl-head">
          <span class="dl-os">{t('download.mac.heading')}</span>
        </div>
        {macItems.map((item) => (
          <div class="dl-row">
            <div class="dl-label">{t(item.labelKey)}</div>
            <div class="dl-actions">
              <a
                class="btn btn-primary btn-sm dl-primary"
                href={item.sources.r2}
                data-src-r2={item.sources.r2}
                data-src-gitee={item.giteeAvailable ? item.sources.gitee : ''}
              >{t('download.source.primary')}</a>
              {item.giteeAvailable && (
                <a class="dl-alt" href={item.sources.gitee} target="_blank" rel="noopener">{t('download.source.gitee')}</a>
              )}
              <a class="dl-alt" href={item.sources.github} target="_blank" rel="noopener">{t('download.source.github')}</a>
            </div>
          </div>
        ))}
      </div>

      <!-- Windows -->
      <div class="card dl-col">
        <div class="dl-head">
          <span class="dl-os">{t('download.win.heading')}</span>
        </div>
        {winItems.map((item) => (
          <div class="dl-row">
            <div class="dl-label">{t(item.labelKey)}</div>
            <div class="dl-actions">
              <a
                class="btn btn-primary btn-sm dl-primary"
                href={item.sources.r2}
                data-src-r2={item.sources.r2}
                data-src-gitee={item.giteeAvailable ? item.sources.gitee : ''}
              >{t('download.source.primary')}</a>
              {item.giteeAvailable && (
                <a class="dl-alt" href={item.sources.gitee} target="_blank" rel="noopener">{t('download.source.gitee')}</a>
              )}
              <a class="dl-alt" href={item.sources.github} target="_blank" rel="noopener">{t('download.source.github')}</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    .download {
      background: var(--bg-soft);
    }
    .china-hint {
      text-align: center;
      color: var(--brand-dark);
      background: var(--brand-tint);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 16px;
      max-width: 560px;
      margin: -24px auto 32px;
      font-size: 0.92rem;
    }
    .dl-grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
    .dl-col {
      padding: 8px 24px 20px;
    }
    .dl-head {
      padding: 18px 0 10px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 8px;
    }
    .dl-os {
      font-weight: 700;
      font-size: 1.15rem;
    }
    .dl-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .dl-row:last-child {
      border-bottom: none;
    }
    .dl-label {
      font-weight: 500;
    }
    .dl-actions {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .dl-alt {
      font-size: 0.85rem;
      color: var(--fg-muted);
    }
    @media (max-width: 860px) {
      .dl-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // 中国用户优先:粗判是否中国大陆(时区 + 语言),若是则
    //  ① 显示 Gitee 提示  ② 把主下载按钮从 R2 切到 Gitee。
    // 只调整默认,不做强制重定向;三个来源始终都列出(用户可自选)。
    function looksChina() {
      try {
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || ''
        const lang = navigator.language || ''
        const zhCN = lang.toLowerCase().startsWith('zh-cn') || lang.toLowerCase() === 'zh'
        const cnTz = tz === 'Asia/Shanghai' || tz === 'Asia/Urumqi' || tz === 'Asia/Chongqing'
        return cnTz || zhCN
      } catch {
        return false
      }
    }
    if (looksChina()) {
      const hint = document.querySelector('[data-china-hint]')
      if (hint) hint.hidden = false
      document.querySelectorAll<HTMLAnchorElement>('.dl-primary').forEach((a) => {
        const gitee = a.getAttribute('data-src-gitee')
        if (gitee) a.href = gitee
      })
    }
  </script>
</section>
